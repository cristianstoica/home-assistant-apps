#!/usr/bin/env bashio
declare exit_code="${1}"

if [[ "${exit_code}" -ne 0 ]] && [[ "${exit_code}" -ne 256 ]]; then
  bashio::log.warning "wxverify exited ${exit_code}, halting add-on"
  echo "${exit_code}" > /run/s6-linux-init-container-results/exitcode
  exec /run/s6/basedir/bin/halt
fi

bashio::log.info "wxverify service restart after closing"
